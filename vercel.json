{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/telegram-link",
      "destination": "/telegram-link.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
